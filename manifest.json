{
    "manifest_version": 3,
    "name": "Apply Helper",
    "version": "1.0",
    "description": "Automatically fills job application forms from profile data.",
    "permissions": ["storage", "scripting", "activeTab"],
    "action": {
      "default_popup": "popup.html"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["profiles.json"],
        "matches": ["<all_urls>"]
      }
    ]
  }
  